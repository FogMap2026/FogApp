# ================================================================
# FogApp 환경 변수 예시 파일
# 이 파일을 복사해 `.env` 로 만들고 실제 값을 채워 넣으세요.
#   cp .env.example .env
# ⚠️ 실제 값이 담긴 .env 는 절대 커밋하지 마세요 (.gitignore 처리됨)
# ================================================================

# ----- 한국관광공사 OpenAPI -----
TOUR_API_SERVICE_KEY=여기에_발급받은_서비스키

# ----- 데이터베이스 (PostgreSQL + PostGIS) -----
# docker-compose.yml 의 기본값과 맞춰져 있습니다.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fogapp
DB_USERNAME=fogapp
DB_PASSWORD=변경하세요

# ----- Naver Maps SDK -----
NAVER_MAP_CLIENT_ID=여기에_네이버_클라이언트_ID

# ----- Firebase (서버측 Admin SDK 사용 시) -----
# 서비스 계정 JSON 파일 경로 (커밋 금지)
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/serviceAccountKey.json

# ----- JWT -----
JWT_SECRET=충분히_긴_랜덤_문자열로_변경
JWT_EXPIRATION_MS=86400000
